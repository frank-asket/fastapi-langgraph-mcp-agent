# Study Coach Next.js — copy to .env.local

# FastAPI base URL (no trailing slash). Must match CORS on the API.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Clerk (required for /studio when the API uses CLERK_ONLY_AUTH)
# Use keys from Clerk Dashboard → API Keys. Copy this file to .env.local (not committed).
# If you use a custom Frontend API domain, set the API’s CLERK_JWT_ISSUER (and CLERK_JWKS_URL) to that same host
# (e.g. https://clerk.example.com) so JWT verification matches session tokens from this app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Same-origin SignIn/SignUp components (see app/sign-in, app/sign-up). Avoids Account Portal subdomains until DNS exists.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# If the API verifies a custom Clerk JWT template, set the same name here and configure CLERK_JWT_AUDIENCE on the API if needed.
# NEXT_PUBLIC_CLERK_JWT_TEMPLATE=
# In production: add https://your-frontend-host to FastAPI CORS_ORIGINS and to
# Clerk Dashboard → Authorized redirect / allowed origins. Align CLERK_AUTHORIZED_PARTIES on the API.
#
# If the app is on one hostname (e.g. study.example.com) and Clerk’s Frontend API on another (clerk.example.com),
# browsers may block clerk-js with CORS when Cloudflare proxies clerk.*. Enable same-origin proxy:
#   1) NEXT_PUBLIC_CLERK_USE_SAME_ORIGIN_FAPI_PROXY=1  (proxy URL is derived from each request’s Host)
#   OR set NEXT_PUBLIC_CLERK_PROXY_URL=https://study.example.com/__clerk/ explicitly.
#   2) Clerk Dashboard → Domains → Frontend API → proxy URL = that same https://study.example.com/__clerk
#      (see https://clerk.com/docs/guides/dashboard/dns-domains/proxy-fapi#enable-proxying )
# Optional: CLERK_FRONTEND_API_URL=https://clerk.example.com if the publishable key parsing ever mismatches.
#
# Custom Clerk hosts (sign-in.example.com, etc.): CNAMEs from Clerk must resolve or you get NXDOMAIN.
# Prefer NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in until Account Portal DNS is verified.
