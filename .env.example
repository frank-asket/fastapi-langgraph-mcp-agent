# Copy to .env and fill in values. Do not commit .env.
# MCP tools & prompts are oriented to Ghana (GES/BECE/SHS/WASSCE & local tertiary).

OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Optional OpenAI-compatible base URL (omit for api.openai.com)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Base URL where this API is reachable (used to build default MCP client URL).
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Next.js app URL (no trailing slash). When set, GET /, /assessment, /chat redirect here;
# successful POST /gate/session redirects to {STUDY_COACH_FRONTEND_URL}{next} (e.g. /studio/chat).
# STUDY_COACH_FRONTEND_URL=http://127.0.0.1:3000

# MCP HTTP endpoint for LangGraph's MultiServerMCPClient (must match mount path).
# Default: {PUBLIC_BASE_URL}/agent/mcp
# MCP_HTTP_URL=http://127.0.0.1:8000/agent/mcp

# Optional: Redis-backed MCP event store (install: pip install redis)
# REDIS_URL=redis://localhost:6379/0

# LangGraph checkpoints: sqlite (default, durable) or memory (MemorySaver; lost on API restart)
# CHECKPOINT_BACKEND=sqlite
# CHECKPOINT_SQLITE_PATH=data/langgraph_checkpoints.db

# Optional LangChain @tool builtins: workspace file read, email (SendGrid), Slack webhook, gated code runner
# BUILTIN_TOOLS_ENABLED=true
# BUILTIN_TOOLS_WORKSPACE_PATH=data/agent_workspace
# BUILTIN_MAX_FILE_READ_BYTES=524288
# BUILTIN_CODE_RUNNER_ENABLED=false
# BUILTIN_CODE_RUNNER_TIMEOUT_S=5
# Slack incoming webhook for agent tool post_slack_message
# SLACK_INCOMING_WEBHOOK_URL=

# --- Pilots & ops (optional) ---
# Session signing for cookie sessions (required when using /gate + SessionMiddleware)
# SESSION_SECRET=long-random-string
# Production: require HTTPS for session cookies when the API is only served over TLS.
# SESSION_COOKIE_SECURE=true

# If set, requests must pass /gate or header X-App-Access-Code (same value).
# APP_ACCESS_CODE=

# Optional comma-separated API keys. When set, auth is required for workflow routes unless keys match
# via header X-API-Key or Authorization: Bearer <key>. Can be combined with APP_ACCESS_CODE.
# API_KEYS=

# Tie each LangGraph thread to the first browser session that uses it (403 if another session reuses thread_id)
# BIND_THREADS_TO_SESSION=false

# SQLite for thread ownership when bind is on (default: data/thread_registry.db)
# THREAD_REGISTRY_DB_PATH=data/thread_registry.db

# slowapi: POST/GET /workflow*, /workflow/history, /workflow/upload, /workflow/stream
# WORKFLOW_REQUESTS_PER_MINUTE=40
# When true, each coach turn includes the learner's saved weekly timetable + workload hints (Studio → Timetable).
# WORKFLOW_TIMETABLE_CONTEXT_ENABLED=true
# Supervisor graph: user-risk scan → safety reply or MCP coach (disable for legacy single-graph behaviour).
# WORKFLOW_SUPERVISOR_ENABLED=true
# Multi-agent team router (requires supervisor): orchestrator → researcher | writer | reviewer | coach subgraphs.
# WORKFLOW_TEAM_ROUTER_ENABLED=false
# Thompson contextual bandit: chooses pedagogy arm per learner bucket (SQLite).
# ADAPTIVE_LEARNING_ENABLED=true
# ADAPTIVE_LEARNING_DB_PATH=data/adaptive_learning.db

# Brute-force protection: POST /gate/session per client IP
# GATE_POSTS_PER_MINUTE=25

# Optional cap applied to every non-exempt route (0 = off). Enabling affects /agent/MCP too — use with care.
# GLOBAL_REQUESTS_PER_MINUTE=0

# Optional shared limiter backend for multi-worker deployments (default: in-memory)
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/2

# X-RateLimit-* response headers (true/false)
# RATE_LIMIT_HEADERS_ENABLED=true

# Trust & safety — anti-hallucination system addendum + verification footer on replies (not a fact-check API)
# TRUST_SAFETY_SYSTEM_ENFORCEMENT=true
# TRUST_SAFETY_REPLY_FOOTER=true
# TRUST_SAFETY_REPLY_FOOTER_TEXT=   # optional override; empty = built-in disclaimer
# TRUST_SAFETY_LOG_RISK_SIGNALS=false   # INFO logs when replies match fee/cut-off heuristics

# CORS: comma-separated allowed browser origins (default in code: Next.js dev on :3000).
# Override in production, e.g. CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
# If the Next.js app and API use different hosts (e.g. https://study.example.com → https://coach.example.com),
# list browser origin(s) here and/or set STUDY_COACH_FRONTEND_URL — else the browser shows CORS errors (no ACAO header).
# CLERK_AUTHORIZED_PARTIES entries that look like http(s) URLs are also merged into the CORS allowlist automatically.
# When CORS_ORIGINS is non-empty, STUDY_COACH_FRONTEND_URL (if set) is merged into the allowlist for convenience.
# If CORS_ORIGINS is empty/whitespace but STUDY_COACH_FRONTEND_URL is set, the API allows that UI origin only
# (typical split-domain: Next.js on study.…, API on coach.…). To disable CORS, leave both unset/empty.
# Cannot use * with credentials. Example SPA dev server:
# CORS_ORIGINS=http://localhost:5173,https://your-app.example.com
# CORS_ALLOW_CREDENTIALS=true
# CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# CORS_ALLOW_HEADERS=*
# CORS_EXPOSE_HEADERS=X-RateLimit-Limit,X-RateLimit-Remaining,X-RateLimit-Reset,Retry-After
# Optional: allow any single-label subdomain of a domain (whole Origin must match the regex):
# CORS_ORIGIN_REGEX=^https://[a-zA-Z0-9][-a-zA-Z0-9]*\.klingbo\.com$

# --- Clerk (optional) — session tokens + subscription ---
# Production checklist (fixes “development keys” + /account/subscription 500 / “Internal Server Error”):
# 1) Clerk Dashboard → your **Production** application → **API keys**: copy **Publishable key** (pk_live_…) and **Secret** (sk_live_…).
# 2) Same screen: copy **JWT issuer** / Frontend API (looks like https://…clerk.accounts.**dev**, a production **.accounts.** host, or your **custom** FAPI domain e.g. https://clerk.example.com) — no trailing slash.
#    If Clerk shows a JWKS URL like https://clerk.example.com/.well-known/jwks.json, set CLERK_JWKS_URL to that exact URL.
#    The dashboard “JWKS public key” (PEM) is the same key material as in that JWKS document; this API verifies via PyJWKClient + CLERK_JWKS_URL (or {issuer}/.well-known/jwks.json) — do not paste PEM into env unless you add custom verification code.
# 3) Set on the **API host** (Railway): CLERK_JWT_ISSUER=<that exact issuer>, optional CLERK_JWKS_URL, CLERK_PUBLISHABLE_KEY optional but useful; CLERK_AUTHORIZED_PARTIES=<your site e.g. https://study.…>.
# 4) Set on **Vercel** (frontend): NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_… (must be the **same** Clerk app as step 2). Never mix pk_test on the site with a live issuer on the API (or the reverse).
# 5) Redeploy API + frontend. If 500 persists, read API logs (Railway “Deploy logs” / stderr) for the real Python traceback — issuer mismatch usually returns 401, not 500.

# Entire-app auth via Clerk only (disables API keys, access code, and /gate cookies for workflow routes).
# Requires CLERK_JWT_ISSUER + CLERK_PUBLISHABLE_KEY. Set CLERK_AUTHORIZED_PARTIES to every browser origin you use (e.g. http://localhost:3000 and http://127.0.0.1:3000) so azp matches.
# CLERK_ONLY_AUTH=true
# Publishable key for embedded sign-in on /chat — use pk_live_… / sk_live_… on production (pk_test_ triggers dev warnings).
# CLERK_PUBLISHABLE_KEY=
# Frontend API URL from Clerk (JWT `iss`, no trailing slash). Custom domain example:
# CLERK_JWT_ISSUER=https://clerk.example.com
# JWKS endpoint (required to match issuer when using custom FAPI; defaults to {CLERK_JWT_ISSUER}/.well-known/jwks.json if unset).
# CLERK_JWKS_URL=https://clerk.example.com/.well-known/jwks.json
# The API server must get HTTP 200 + JSON from that URL (curl from laptop is not enough — try curl from Railway/host).
# If you see 403/HTML from Cloudflare, JWT verification fails and all coach routes return 401 until DNS/proxy is fixed.
# Optional: reachable instance JWKS (Dashboard) so verify_clerk_session_jwt can fall back when the custom-domain JWKS is blocked:
# CLERK_JWKS_FALLBACK_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# Example (Clerk default dev host):
# CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev
# Optional JWT audience verification (leave unset for Clerk’s default session JWT — it usually has no aud):
# CLERK_JWT_AUDIENCE=
# Recommended: comma-separated origins that may appear in the session token azp claim (e.g. your SPA URL).
# These URLs are also merged into the API CORS allowlist (split study. / coach. deploys: include https://study.… here).
# In production use pk_live / your live Clerk instance — pk_test triggers “development keys” warnings and must match CLERK_JWT_ISSUER on this API.
# CLERK_AUTHORIZED_PARTIES=http://localhost:3000,https://your-app.com
# CLERK_REJECT_ORG_PENDING_STATUS=false
# Webhook signing secret (whsec_...) — register https://your-api/webhooks/clerk in Clerk dashboard.
# CLERK_WEBHOOK_SECRET=
# SendGrid welcome email on user.created (needs SENDGRID_API_KEY + verified sender; set STUDY_COACH_FRONTEND_URL for app links).
# CLERK_SEND_WELCOME_EMAIL=true
# SQLite for subscription fields synced from user.updated webhooks (public_metadata.subscription_status).
# CLERK_ENTITLEMENTS_DB_PATH=data/clerk_entitlements.db
# CLERK_ENFORCE_SUBSCRIPTION=false
# JWT claim added via Clerk session template (e.g. map public_metadata.subscription_status).
# CLERK_SUBSCRIPTION_JWT_CLAIM=subscription_status
# CLERK_SUBSCRIPTION_ACTIVE_VALUES=active,trialing
# Also require a matching row synced via webhooks (both JWT + DB when both claim and this are set):
# CLERK_ENFORCE_ENTITLEMENTS_DB=false
# Optional link shown in Studio → Settings → Subscription (Stripe Customer Portal, Clerk Billing page, etc.)
# SUBSCRIPTION_MANAGE_URL=

# --- Timetable nudges (SQLite + optional SendGrid) ---
# TIMETABLE_DB_PATH=data/timetable.db
# TIMETABLE_NOTIFICATIONS_ENABLED=true
# When true and OPENAI_API_KEY is set, prep / rest / daily-focus nudges analyse the saved timetable (what/how/when/rest).
# TIMETABLE_NOTIFY_AI_ENABLED=true
# Optional model for those nudges only (defaults to OPENAI_MODEL).
# TIMETABLE_NOTIFY_AI_MODEL=gpt-4o-mini
# SendGrid API key for email nudges (from noreply@klingbo.com — verify domain in SendGrid).
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=noreply@klingbo.com
# SENDGRID_FROM_NAME=Klingbo Study Coach
# Optional: absolute path to PNG logo for inline email (defaults to frontend/public/images/landing/kifinal.png)
# TIMETABLE_BRAND_LOGO_PATH=
# Optional: reference grid PNG for AI import only (defaults to frontend/public/images/timetable-calendar-template.png)
# TIMETABLE_REFERENCE_LAYOUT_PATH=
# Coach chat "Email to me" (POST /workflow/email-export) — hourly cap per user session / IP; max body size (chars).
# COACH_EMAIL_EXPORTS_PER_HOUR=8
# COACH_EMAIL_EXPORT_MAX_BODY_CHARS=100000
